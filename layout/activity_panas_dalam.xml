<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PanasDalam">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="PANAS DALAM"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="2mm"
            android:gravity="left|center"
            android:text="\t\tPanas dalam bukanlah suatu penyakit. Akan tetapi, salah satu gejala yang dapat dirasakan pada tenggorokan. Panas dalam dapat dikenali dari beberapa gejalanya yang khas. Penderita panas dalam biasanya akan mengalami rasa tidak nyaman pada tenggorokan, terasa sakit ketika sedang menelan, bau mulut, hingga bibir kering dan pecah-pecah."
            android:textSize="15sp" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/alang"/>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>